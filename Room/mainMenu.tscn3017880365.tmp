[sub_resource type="GDScript" id="GDScript_u2isg"]
script/source = "extends Node3D

var is_mouse_inside = false
var last_event_pos2D = null
var last_event_time: float = -1.0

@onready var node_viewport = %SubViewport_menu
@onready var node_quad = %screen_menu
@onready var node_area = %Area3D

@export var billboard := false

func _ready():
	node_area.mouse_entered.connect(_mouse_entered_area)
	node_area.mouse_exited.connect(_mouse_exited_area)
	node_area.input_event.connect(_mouse_input_event)

	if !billboard:
		set_process(false)


func _process(_delta):
	rotate_area_to_billboard()


func _mouse_entered_area():
	is_mouse_inside = true
	
	# viewport recebe foco apenas quando mouse está diretamente encima
	node_viewport.gui_disable_input = false


func _mouse_exited_area():
	is_mouse_inside = false
	
	# remove foco/input quando mouse sai
	node_viewport.gui_disable_input = true


func _unhandled_input(event):
	# NÃO envia input se mouse não estiver encima
	if !is_mouse_inside:
		return

	for mouse_event in [
		InputEventMouseButton,
		InputEventMouseMotion,
		InputEventScreenDrag,
		InputEventScreenTouch
	]:
		if is_instance_of(event, mouse_event):
			return

	node_viewport.push_input(event)


func _mouse_input_event(
	_camera: Camera3D,
	event: InputEvent,
	event_position: Vector3,
	_normal: Vector3,
	_shape_idx: int
):
	# ignora completamente se mouse não estiver encima
	if !is_mouse_inside:
		return

	var quad_mesh_size = node_quad.mesh.size
	var event_pos3D = event_position

	var now: float = Time.get_ticks_msec() / 1000.0

	event_pos3D = node_quad.global_transform.affine_inverse() * event_pos3D

	var event_pos2D: Vector2 = Vector2()

	event_pos2D = Vector2(event_pos3D.x, -event_pos3D.y)

	event_pos2D.x = event_pos2D.x / quad_mesh_size.x
	event_pos2D.y = event_pos2D.y / quad_mesh_size.y

	event_pos2D.x += 0.5
	event_pos2D.y += 0.5

	event_pos2D.x *= node_viewport.size.x
	event_pos2D.y *= node_viewport.size.y

	event.position = event_pos2D

	if event is InputEventMouse:
		event.global_position = event_pos2D

	if event is InputEventMouseMotion or event is InputEventScreenDrag:
		if last_event_pos2D == null:
			event.relative = Vector2.ZERO
		else:
			event.relative = event_pos2D - last_event_pos2D
			event.velocity = event.relative / (now - last_event_time)

	last_event_pos2D = event_pos2D
	last_event_time = now

	node_viewport.push_input(event)


func rotate_area_to_billboard():
	var billboard_mode = node_quad.get_surface_override_material(0).params_billboard_mode

	if billboard_mode > 0:
		var camera = get_viewport().get_camera_3d()

		var look = camera.to_global(Vector3(0, 0, -100)) - camera.global_transform.origin
		look = node_area.position + look

		if billboard_mode == 2:
			look = Vector3(look.x, 0, look.z)

		node_area.look_at(look, Vector3.UP)
		node_area.rotate_object_local(Vector3.BACK, camera.rotation.z)
"

