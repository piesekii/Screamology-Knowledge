[sub_resource type="GDScript" id="GDScript_4qo4c"]
script/source = "extends Node3D

@onready var pc_mm: PhantomCamera3D = $\"../MM/PC_MM\"
@onready var pc_mm_2: PhantomCamera3D = $PC_MM2

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if pc_mm_2._is_active:
		if Input.is_action_just_pressed(\"ui_accept\") or Input.is_action_just_pressed(\"interact\") or Input.is_action_just_pressed(\"left\"):
			pc_mm.priority = GlobalScript.counter_camera + 1


func _on_button_settings_pressed() -> void:
	pc_mm2.priority = GlobalScript.counter_camera + 1
"

